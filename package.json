{
  "name": "daily-vedic-astro",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "workspaces": [
    "worker"
  ],
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit && npm run typecheck --workspace worker",
    "worker:dev": "npm run dev --workspace worker",
    "worker:deploy": "npm run deploy --workspace worker",
    "worker:db:local": "npm run db:local --workspace worker",
    "worker:db:remote": "npm run db:remote --workspace worker"
  },
  "dependencies": {
    "@react-native-community/datetimepicker": "latest",
    "@tanstack/react-query": "latest",
    "expo": "~56.0.12",
    "expo-constants": "latest",
    "expo-device": "latest",
    "expo-haptics": "latest",
    "expo-image": "latest",
    "expo-linear-gradient": "latest",
    "expo-linking": "latest",
    "expo-localization": "latest",
    "expo-notifications": "latest",
    "expo-router": "~56.2.11",
    "expo-secure-store": "latest",
    "expo-sqlite": "latest",
    "expo-status-bar": "~56.0.4",
    "lucide-react-native": "latest",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-purchases": "^10.4.0",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "latest",
    "react-native-svg": "15.15.4",
    "react-native-web": "latest",
    "react-native-worklets": "0.8.3"
  },
  "devDependencies": {
    "@types/react": "latest",
    "eslint": "^9.0.0",
    "eslint-config-expo": "latest",
    "sharp": "^0.34.0",
    "typescript": "~6.0.3"
  }
}
