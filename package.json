{
  "name": "daily-vedic-astro",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "packageManager": "npm@10.8.2",
  "engines": {
    "node": "20.19.4",
    "npm": "10.8.2"
  },
  "workspaces": [
    "worker"
  ],
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit && npm run typecheck --workspace worker",
    "verify:reproducible": "node scripts/verify-reproducible-toolchain.mjs",
    "worker:dev": "npm run dev --workspace worker",
    "worker:deploy": "npm run deploy --workspace worker",
    "worker:db:local": "npm run db:local --workspace worker",
    "worker:db:remote": "npm run db:remote --workspace worker"
  },
  "dependencies": {
    "@react-native-community/datetimepicker": "9.1.0",
    "@tanstack/react-query": "5.101.1",
    "expo": "56.0.17",
    "expo-constants": "56.0.22",
    "expo-device": "56.0.4",
    "expo-haptics": "56.0.3",
    "expo-image": "57.0.1",
    "expo-linear-gradient": "56.0.4",
    "expo-linking": "56.0.16",
    "expo-localization": "56.0.6",
    "expo-notifications": "56.0.22",
    "expo-router": "56.2.16",
    "expo-secure-store": "56.0.4",
    "expo-sqlite": "56.0.5",
    "expo-status-bar": "56.0.4",
    "lucide-react-native": "1.21.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "2.31.2",
    "react-native-purchases": "10.4.0",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "5.7.0",
    "react-native-screens": "4.26.0",
    "react-native-svg": "15.15.4",
    "react-native-web": "0.21.2",
    "react-native-worklets": "0.8.3"
  },
  "devDependencies": {
    "@types/react": "19.2.17",
    "eslint": "9.39.4",
    "eslint-config-expo": "56.0.4",
    "sharp": "0.34.5",
    "typescript": "6.0.3"
  }
}
